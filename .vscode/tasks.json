{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build",
            "type": "shell",
            "command": "cmake --build build",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Flash",
            "type": "shell",
            "command": "openocd -f openocd.cfg -c \"program build/stm32_drivers.hex verify reset exit\"",
            "problemMatcher": []
        }
    ]
}